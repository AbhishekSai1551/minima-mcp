# Minima MCP Server Configuration

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
LOG_LEVEL=info

# Minima Node Connection
MINIMA_DATA_HOST=localhost
MINIMA_DATA_PORT=9004
MINIMA_MINIDAPP_HOST=localhost
MINIMA_MINIDAPP_PORT=9005
MINIMA_TIMEOUT=30s
MINIMA_RETRY_ATTEMPTS=3
MINIMA_RETRY_DELAY=1s

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
RATE_LIMIT_CLEANUP=5m

# Structured Audit Logging (SOC 2)
AUDIT_ENABLED=true
AUDIT_LOG_DIR=./audit-logs
AUDIT_MAX_AGE_DAYS=90
AUDIT_FORMAT=json

# Authentication & Access Boundaries
# Modes: tiered (read-only public, write requires auth), false (all public), full (all require auth)
AUTH_ENABLED=true
AUTH_MODE=tiered
# AUTH_JWT_SECRET=change-me-in-production
# AUTH_ONBOARDING_DN=